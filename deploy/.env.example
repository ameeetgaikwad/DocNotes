# Copy to /opt/docnotes/.env on the server. Never commit the filled-in version.
# This .env serves BOTH staging and prod (backends share one Neon DB).

# ---- Database (shared) ----
# Neon connection string (with ?sslmode=require)
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxxx.aws.neon.tech/docnotes?sslmode=require

# ---- CORS origins (per env) ----
# Web app's Vercel URL(s). Comma-separated if multiple.
CORS_ORIGINS_PROD=https://docnotes.vercel.app
CORS_ORIGINS_STAGING=https://docnotes-staging.vercel.app,http://localhost:3000

# ---- Hostnames for Caddy + Let's Encrypt ----
# sslip.io resolves any IP-based hostname to that IP.
# Use api-<dashed-server-ip>.sslip.io for prod and staging-api-<dashed-server-ip>.sslip.io for staging.
# Replace 203-0-113-7 with your Hetzner server's actual IP (with dots → dashes).
API_DOMAIN_PROD=api-203-0-113-7.sslip.io
API_DOMAIN_STAGING=staging-api-203-0-113-7.sslip.io

# ---- Image tags (set automatically by GH Actions on each deploy) ----
# These get rewritten by the deploy workflow to point at the latest image SHA.
# Initial values are fine; CI will overwrite them on first push.
BACKEND_PROD_IMAGE=ghcr.io/OWNER/docnotes-backend:latest
BACKEND_STAGING_IMAGE=ghcr.io/OWNER/docnotes-backend:staging

# ---- Clerk (auth) ----
CLERK_SECRET_KEY=sk_live_...

# ---- Object storage — Cloudflare R2 (Documents feature) ----
# Required for the patient Documents upload/download flow. Without these
# the upload presign call fails with "Could not load credentials from any
# providers" and the feature is unusable.
#
# Defaults below target Cloudflare R2. For AWS S3, MinIO, or another
# S3-compatible store, override S3_ENDPOINT and AWS_REGION accordingly
# (AWS S3: leave S3_ENDPOINT blank and set AWS_REGION to e.g. ap-south-1).
#
# Setup (one-time, via the Cloudflare dashboard):
#   1. R2 → Create bucket `docnotes-documents` (Public access OFF —
#      the app uses presigned PUTs).
#   2. R2 → Manage R2 API Tokens → Create API Token. Permission:
#      "Object Read & Write", scoped to this bucket. Copy the Access
#      Key ID + Secret (the secret is shown only once).
#   3. Note your Account ID — endpoint is
#      https://<account-id>.r2.cloudflarestorage.com.
#   4. Bucket → Settings → CORS Policy, paste:
#        [
#          {
#            "AllowedOrigins": [
#              "https://docnotes.ameeet.com",
#              "https://staging.docnotes.ameeet.com"
#            ],
#            "AllowedMethods": ["GET", "PUT", "HEAD"],
#            "AllowedHeaders": ["*"],
#            "ExposeHeaders": ["ETag"],
#            "MaxAgeSeconds": 3600
#          }
#        ]
#   5. Fill the two blanks below + your account ID in S3_ENDPOINT, then
#      `docker compose up -d` on the Hetzner box to restart both
#      backend containers with the new env.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# R2 ignores region beyond requiring a non-empty value; "auto" is the
# documented choice. AWS S3 wants a real region (e.g. ap-south-1).
AWS_REGION=auto
S3_BUCKET=docnotes
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
