# Backend API base URL (no trailing slash). The tRPC client appends /trpc.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public web origin used to build sharable URLs in share-dialog.
# In production this should be your Vercel domain (e.g. https://docnotes.app).
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Clerk publishable key — exposed to the browser; safe to commit in .env.local
# but NOT here. Get it from dashboard.clerk.com → API keys.
# Format: pk_test_... (dev) or pk_live_... (prod).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# Clerk secret key — server-only. Used by Next.js middleware (edge runtime)
# and any server actions / route handlers. Never expose this to the browser.
# Format: sk_test_... (dev) or sk_live_... (prod).
CLERK_SECRET_KEY=sk_test_replace_me
